# Udev rules for Smackbio SB1001U USB Fingerprint Scanner & SCSI generic nodes
# Sets mode 0666 and dialout/disk group for seamless Linux scanner hardware access

KERNEL=="sg*", MODE="0666", GROUP="dialout"
SUBSYSTEM=="scsi_generic", MODE="0666", GROUP="dialout"
SUBSYSTEM=="usb", ATTRS{idVendor}=="2009", ATTRS{idProduct}=="7638", MODE="0666", GROUP="dialout"
